---
import { Badge, Icon } from '@astrojs/starlight/components';
import SidebarRestorePoint from '@astrojs/starlight/components/SidebarRestorePoint.astro';
import { flattenSidebar } from '@astrojs/starlight/utils/navigation';
import type { SidebarEntry } from '@astrojs/starlight/utils/routing/types';
import { getSidebarGroupIcon } from '../lib/sidebar-icons';

interface Props {
	sublist: SidebarEntry[];
	nested?: boolean;
}

const { sublist, nested } = Astro.props;
---

<ul class:list={{ 'top-level': !nested }}>
	{
		sublist.map((entry) => (
			<li>
				{entry.type === 'link' ? (
					<a
						href={entry.href}
						aria-current={entry.isCurrent ? 'page' : undefined}
						class:list={[{ large: !nested }, entry.attrs.class]}
						{...entry.attrs}
					>
						<span>{entry.label}</span>
						{entry.badge && (
							<Badge
								variant={entry.badge.variant}
								class={entry.badge.class}
								text={entry.badge.text}
							/>
						)}
					</a>
				) : (
					<details
						class:list={{ 'sidebar-group': !nested }}
						open={flattenSidebar(entry.entries).some((i) => i.isCurrent) || !entry.collapsed}
					>
						<summary>
							<span class="group-label">
								{!nested && getSidebarGroupIcon(entry.label) && (
									<Icon
										name={getSidebarGroupIcon(entry.label)!}
										class="group-icon"
										size="1rem"
									/>
								)}
								<span class="large">{entry.label}</span>
								{entry.badge && (
									<Badge
										variant={entry.badge.variant}
										class={entry.badge.class}
										text={entry.badge.text}
									/>
								)}
							</span>
							<Icon name="right-caret" class="caret" size="1.25rem" />
						</summary>
						<SidebarRestorePoint />
						<Astro.self sublist={entry.entries} nested />
					</details>
				)}
			</li>
		))
	}
</ul>

<style>
	@layer starlight.core {
		ul {
			--sl-sidebar-item-padding-inline: 0.5rem;
			list-style: none;
			padding: 0;
		}

		li {
			overflow-wrap: anywhere;
		}

		ul ul li {
			margin-inline-start: var(--sl-sidebar-item-padding-inline);
			border-inline-start: 1px solid var(--sl-color-hairline-light);
			padding-inline-start: var(--sl-sidebar-item-padding-inline);
		}

		.large {
			font-size: var(--sl-text-lg);
			font-weight: 600;
			color: var(--sl-color-white);
		}

		.top-level > li + li {
			margin-top: 0.75rem;
		}

		.top-level > li > details.sidebar-group {
			border-top: 1px solid var(--sl-color-hairline);
			padding-top: 0.75rem;
		}

		.top-level > li:first-child > details.sidebar-group {
			border-top: none;
			padding-top: 0;
		}

		summary {
			display: flex;
			align-items: center;
			justify-content: space-between;
			padding: 0.35em var(--sl-sidebar-item-padding-inline);
			line-height: 1.4;
			cursor: pointer;
			user-select: none;
			transition: color 0.15s ease;
		}

		summary:hover {
			color: var(--sl-color-accent-high);
		}

		summary::marker,
		summary::-webkit-details-marker {
			display: none;
		}

		.group-label {
			display: inline-flex;
			align-items: center;
			gap: 0.45rem;
		}

		.group-icon {
			color: var(--sl-color-accent);
			flex-shrink: 0;
		}

		.top-level > li > details.sidebar-group > summary .large {
			font-family: var(--sl-font-mono);
			font-size: var(--sl-text-xs);
			font-weight: 700;
			letter-spacing: 0.1em;
			text-transform: uppercase;
			color: var(--sl-color-gray-3);
		}

		.top-level > li > details.sidebar-group[open] > summary .large {
			color: var(--sl-color-gray-2);
		}

		.caret {
			transition:
				transform 0.2s ease-in-out,
				color 0.15s ease;
			flex-shrink: 0;
			color: var(--sl-color-gray-4);
		}

		summary:hover .caret,
		[open] > summary .caret {
			color: var(--sl-color-accent);
		}

		:global([dir='rtl']) .caret {
			transform: rotateZ(180deg);
		}

		[open] > summary .caret {
			transform: rotateZ(90deg);
		}

		a {
			display: block;
			text-decoration: none;
			color: var(--sl-color-gray-2);
			padding: 0.45em var(--sl-sidebar-item-padding-inline);
			line-height: 1.4;
			transition:
				color 0.15s ease,
				background-color 0.15s ease;
		}

		a:hover,
		a:focus {
			color: var(--sl-color-white);
			background: rgba(200, 255, 0, 0.06);
		}

		[aria-current='page'],
		[aria-current='page']:hover,
		[aria-current='page']:focus {
			font-weight: 600;
			color: var(--sl-color-accent-high);
			background: rgba(200, 255, 0, 0.1);
			border-left: 2px solid var(--sl-color-accent);
		}

		a > *:not(:last-child),
		.group-label > *:not(:last-child) {
			margin-inline-end: 0.25em;
		}

		@media (min-width: 50rem) {
			.top-level > li + li {
				margin-top: 0.5rem;
			}

			.large {
				font-size: var(--sl-text-base);
			}

			a {
				font-size: var(--sl-text-sm);
			}
		}
	}
</style>
